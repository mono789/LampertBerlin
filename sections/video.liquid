{{ 'section-video.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

{% style %}
   {% render 'spaced-section' %}
  #shopify-section-{{ section.id }} .video-section{
  			--section-overlay : rgba(var(--color-overlay), {{ section.settings.overlay_opacity }}%);
  		}
{% endstyle %}

{% liquid
  if section.settings.header_overlay == true and section.settings.full_width
    assign has_overlay = true
  else
    assign has_overlay = false
  endif
%}

<div
  class="video-section color-inverse {% if section.settings.full_width != true %}container{% endif %}"
  {% if has_overlay %}
    data-header-overlay="true"
  {% endif %}
>
  <noscript>
    <div
      class="video-section__media {% if section.settings.overlay_enable %}have-overlay{% endif %}"
      {% if section.settings.cover_image != blank %}
        style="padding-bottom: {{ 1 | divided_by: section.settings.cover_image.aspect_ratio | times: 100 }}%;"
      {% endif %}
    >
      <a
        href="{{ section.settings.video_url }}"
        class="video-section__poster media media--transparent{% if section.settings.cover_image == blank %} video-section__placeholder{% endif %}"
      >
        {% if section.settings.cover_image != blank %}
          {% assign image_height = section.settings.cover_image.width
            | divided_by: section.settings.cover_image.aspect_ratio
          %}
          {{
            section.settings.cover_image
            | image_url: width: 3840
            | image_tag:
              loading: 'lazy',
              width: section.settings.cover_image.width,
              height: image_height,
              sizes: '100vw',
              widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
          }}
        {%- else -%}
          {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
        {%- endif -%}
        <div class="video-section__content">
          {% if section.settings.subheading != blank %}
            <div class="video-section__subheading subtitle">
              {{ section.settings.subheading | truncate: 30, '' | escape }}
            </div>
          {% endif %}

          {% if section.settings.heading != blank %}
            <{{ section.settings.heading_tag }} class="title title--section video-section__heading h2">
              {{ section.settings.heading | truncate: 30, '' | escape }}
            </{{ section.settings.heading_tag }}>
          {% endif %}
          <span class="video-section__play-button">
            {% render 'icon-play' %}
          </span>
        </div>
      </a>
    </div>
  </noscript>
  <deferred-media
    class="video-section__media video-section__media--{{ section.settings.height }} video-section__media--{{ section.settings.video_fit }} deferred-media no-js-hidden {% if section.settings.overlay_enable %}have-overlay{% endif %}"
    data-media-id="{{ section.settings.video_url.id }}"
    {%- if section.settings.video_autoplay -%}
      data-autoplay="true"
    {%- endif -%}
    {% liquid
      assign desktop_height = section.settings.height
      assign mobile_height = section.settings.height_mobile | default: desktop_height
    %}
    style="
      {% if desktop_height == 'adapt' and section.settings.video != blank %}
      	--desktop-ratio: {{ 1 | divided_by: section.settings.video.aspect_ratio | times: 100 }}%;
      {% else %}
      	--desktop-aspect: {{ desktop_height }};
      {% endif %}

      {% if mobile_height == 'adapt' and section.settings.mobile_video != blank %}
      	--mobile-ratio: {{ 1 | divided_by: section.settings.mobile_video.aspect_ratio | times: 100 }}%;
      {% elsif mobile_height == 'adapt' and section.settings.video != blank %}
      	--mobile-ratio: {{ 1 | divided_by: section.settings.video.aspect_ratio | times: 100 }}%;
      {% else %}
      	--mobile-aspect: {{ mobile_height }};
      {% endif %}
    "
  >
    {%- if section.settings.video_autoplay != true -%}
      <button
        id="Deferred-Poster-Modal-{{ section.settings.video_url.id }}"
        class="video-section__poster media deferred-media__poster media--landscape"
        type="button"
      >
        <span class="video-section__overlay"></span>
        {%- if section.settings.cover_image != blank -%}
          {% assign image_height = section.settings.cover_image.width
            | divided_by: section.settings.cover_image.aspect_ratio
          %}
          {{
            section.settings.cover_image
            | image_url: width: 3840
            | image_tag:
              loading: 'lazy',
              width: section.settings.cover_image.width,
              height: image_height,
              sizes: '100vw',
              widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
          }}
        {%- else -%}
          {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
        {%- endif -%}
        <div class="video-section__content">
          {% if section.settings.subheading != blank %}
            <div class="video-section__subheading subtitle">
              {{ section.settings.subheading | truncate: 30, '' | escape }}
            </div>
          {% endif %}

          {% if section.settings.heading != blank %}
            <{{ section.settings.heading_tag }} class="title title--section video-section__heading h2">
              {{ section.settings.heading | truncate: 30, '' | escape }}
            </{{ section.settings.heading_tag }}>
          {% endif %}
          <span class="video-section__play-button">
            {% render 'icon-play' %}
          </span>
        </div>
      </button>
    {% endif %}
    <template>
      {% liquid
        assign desktop_video = section.settings.video
        assign mobile_video = section.settings.mobile_video
        assign video_url = section.settings.video_url
        assign has_desktop_video = false
        assign has_mobile_video = false
        assign has_video_url = false
        assign use_both = false

        if desktop_video != blank
          assign has_desktop_video = true
        endif
        if mobile_video != blank
          assign has_mobile_video = true
        endif
        if video_url != blank
          assign has_video_url = true
        endif
        if has_desktop_video and has_mobile_video
          assign use_both = true
        endif
      %}

      {%- if has_video_url and has_desktop_video == false and has_mobile_video == false -%}
        {%- if video_url.type == 'youtube' -%}
          <iframe
            src="https://www.youtube.com/embed/{{ video_url.id }}?enablejsapi=1&autoplay=1{%- if section.settings.video_autoplay -%}&mute=1{%- endif -%}{%- if section.settings.video_autoplay != true and section.settings.video_muted -%}&mute=1{%- endif -%}{%- if section.settings.video_controls != true -%}&controls=0{%- endif -%}{%- if section.settings.video_loop -%}&playlist={{ video_url.id }}&loop=1{%- endif -%}"
            class="video-embed video-embed--youtube"
            allow="autoplay; encrypted-media"
            allowfullscreen
            title="{{ section.settings.description | escape }}"
          ></iframe>
        {%- else -%}
          <iframe
            src="https://player.vimeo.com/video/{{ video_url.id }}?autoplay=true{%- if section.settings.video_autoplay -%}&muted=true{%- endif -%}{%- if section.settings.video_autoplay != true and section.settings.video_muted -%}&muted=true{%- endif -%}{%- if section.settings.video_controls != true -%}&controls=false{%- endif -%}{%- if section.settings.video_loop -%}&loop=true{%- endif -%}"
            class="video-embed video-embed--vimeo"
            allow="autoplay; encrypted-media"
            allowfullscreen
            title="{{ section.settings.description | escape }}"
          ></iframe>
        {%- endif -%}
      {%- elsif has_desktop_video or has_mobile_video -%}
        <div class="video-container">
          {% liquid
            assign muted = section.settings.video_muted
            if section.settings.video_autoplay
              assign muted = true
            endif
          %}
          {%- if use_both -%}
            <div class="video-container__desktop">
              {{
                desktop_video
                | video_tag:
                  image_size: '1300x',
                  autoplay: section.settings.video_autoplay,
                  loop: section.settings.video_loop,
                  controls: section.settings.video_controls,
                  muted: muted
              }}
            </div>
            <div class="video-container__mobile">
              {{
                mobile_video
                | video_tag:
                  image_size: '1300x',
                  autoplay: section.settings.video_autoplay,
                  loop: section.settings.video_loop,
                  controls: section.settings.video_controls,
                  muted: muted
              }}
            </div>
          {%- elsif has_desktop_video -%}
            <div class="video-container__single">
              {{
                desktop_video
                | video_tag:
                  image_size: '1300x',
                  autoplay: section.settings.video_autoplay,
                  loop: section.settings.video_loop,
                  controls: section.settings.video_controls,
                  muted: muted
              }}
            </div>
          {%- elsif has_mobile_video -%}
            <div class="video-container__single">
              {{
                mobile_video
                | video_tag:
                  image_size: '1300x',
                  autoplay: section.settings.video_autoplay,
                  loop: section.settings.video_loop,
                  controls: section.settings.video_controls,
                  muted: muted
              }}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </template>
  </deferred-media>
</div>

{% schema %}
{
  "name": "t:sections.video.name",
  "tag": "section",
  "class": "spaced-section",
  "enabled_on": {
    "templates": ["*"],
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "header_overlay",
      "label": "t:sections.all.header_overlay.label",
      "info": "t:sections.all.header_overlay.info",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": true,
      "label": "t:sections.video.settings.full_width.label"
    },
    {
      "type": "select",
      "id": "height",
      "options": [
        {
          "value": "1/1",
          "label": "t:sections.video.settings.height.options__1.label"
        },
        {
          "value": "3/2",
          "label": "t:sections.video.settings.height.options__2.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.video.settings.height.options__3.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.video.settings.height.options__4.label"
        },
        {
          "value": "21/9",
          "label": "t:sections.video.settings.height.options__5.label"
        },
        {
          "value": "adapt",
          "label": "t:sections.video.settings.height.options__6.label"
        }
      ],
      "default": "16/9",
      "label": "t:sections.video.settings.height.label",
      "info": "t:sections.video.settings.height.info"
    },
    {
      "type": "select",
      "id": "height_mobile",
      "options": [
        {
          "value": "1/1",
          "label": "t:sections.video.settings.height.options__1.label"
        },
        {
          "value": "3/2",
          "label": "t:sections.video.settings.height.options__2.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.video.settings.height.options__3.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.video.settings.height.options__4.label"
        },
        {
          "value": "21/9",
          "label": "t:sections.video.settings.height.options__5.label"
        },
        {
          "value": "adapt",
          "label": "t:sections.video.settings.height.options__6.label"
        }
      ],
      "default": "16/9",
      "label": "t:sections.video.settings.height.mobile_label",
      "info": "t:sections.video.settings.height.info"
    },
    {
      "type": "select",
      "id": "video_fit",
      "label": "t:sections.video.settings.video_fit.label",
      "options": [
        {
          "value": "contain",
          "label": "t:sections.video.settings.video_fit.options__1.label"
        },
        {
          "value": "cover",
          "label": "t:sections.video.settings.video_fit.options__2.label"
        }
      ],
      "default": "contain",
      "info": "t:sections.video.settings.video_fit.info"
    },
    {
      "type": "text",
      "id": "subheading",
      "default": "t:sections.video.settings.subheading.default",
      "label": "t:sections.video.settings.subheading.label",
      "info": "t:sections.video.settings.subheading.info"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.video.settings.heading.default",
      "label": "t:sections.all.heading.label",
      "info": "t:sections.video.settings.heading.info"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        },
        {
          "value": "p",
          "label": "t:sections.all.heading_tag.options__8.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_tag.label",
      "info": "t:sections.all.heading_tag.info"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "t:sections.video.settings.cover_image.label"
    },
    {
      "type": "header",
      "content": "t:sections.video.settings.header__1.content"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.video.settings.video.label"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "t:sections.video.settings.mobile_video.label"
    },
    {
      "type": "header",
      "content": "t:sections.video.settings.header__2.content"
    },
    {
      "type": "paragraph",
      "content": "t:sections.video.settings.paragraph.content"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "default": "https:\/\/www.youtube.com\/watch?v=_9VUPq3SxOc",
      "label": "t:sections.video.settings.video_url.label",
      "info": "t:sections.video.settings.video_url.info"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "default": false,
      "label": "t:sections.video.settings.video_autoplay.label"
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "default": false,
      "label": "t:sections.video.settings.video_loop.label"
    },
    {
      "type": "checkbox",
      "id": "video_muted",
      "default": false,
      "label": "t:sections.video.settings.video_muted.label",
      "info": "t:sections.video.settings.video_muted.info"
    },
    {
      "type": "checkbox",
      "id": "video_controls",
      "default": true,
      "label": "t:sections.video.settings.video_controls.label"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.video.settings.description.label",
      "info": "t:sections.video.settings.description.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.overlay.header.content"
    },
    {
      "type": "checkbox",
      "id": "overlay_enable",
      "default": true,
      "label": "t:sections.all.overlay.overlay_enable.label"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 10,
      "max": 90,
      "default": 20,
      "unit": "%",
      "label": "t:sections.all.overlay.overlay_opacity.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section_margin.header.content"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 20,
      "unit": "px",
      "label": "t:sections.all.section_margin.margin_top.label"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 20,
      "unit": "px",
      "label": "t:sections.all.section_margin.margin_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.video.presets.name"
    }
  ]
}
{% endschema %}
