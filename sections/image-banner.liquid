{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% render 'spaced-section' %}
  {% render 'spaced-section-inner' %}
  #shopify-section-{{ section.id }} .image-banner {
  	--slide-overlay : rgba(var(--color-overlay), {{ section.settings.overlay_opacity }}%);
  }
{%- endstyle -%}

{% liquid
  comment
    Desktop image size
  endcomment
  case section.settings.image_size
    when 'adapt'
      assign desktop_section_size = 0
    when 'small'
      assign desktop_section_size = '300px'
    when 'medium'
      assign desktop_section_size = '600px'
    when 'large'
      assign desktop_section_size = '100vh'
    else
      assign desktop_section_size = '100vh'
  endcase

  comment
    Mobile image size
  endcomment
  case section.settings.mobile_image_size
    when 'adapt'
      assign mobile_section_size = 0
    when 'small'
      assign mobile_section_size = '300px'
    when 'medium'
      assign mobile_section_size = '600px'
    when 'large'
      assign mobile_section_size = '100vh'
    else
      assign mobile_section_size = '600px'
  endcase
%}

{% liquid
  if section.settings.image != blank and section.settings.mobile_image == blank
    assign image = section.settings.image
  elsif section.settings.image == blank and section.settings.mobile_image != blank
    assign image = section.settings.mobile_image
  elsif section.settings.image != blank and section.settings.mobile_image != blank
    assign image = 1
  endif
%}

{% liquid
  comment
    Desktop adapt height (uses desktop image)
  endcomment
  if section.settings.image != blank and section.settings.image_size == 'adapt'
    assign desktop_adapt_height = 1 | divided_by: section.settings.image.aspect_ratio | times: 100 | append: '%'
    assign desktop_section_size = desktop_adapt_height
  endif

  comment
    Mobile adapt height (uses mobile image, falls back to desktop image)
  endcomment
  assign mobile_image_for_adapt = section.settings.mobile_image | default: section.settings.image
  if mobile_image_for_adapt != blank and section.settings.mobile_image_size == 'adapt'
    assign mobile_adapt_height = 1 | divided_by: mobile_image_for_adapt.aspect_ratio | times: 100 | append: '%'
    assign mobile_section_size = mobile_adapt_height
  endif

  if section.settings.header_overlay == true
    assign has_overlay = true
  else
    assign has_overlay = false
  endif
%}

{% liquid
  if section.settings.image != blank
    assign desktop_image_height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio
  endif
  if section.settings.mobile_image != blank
    assign mobile_image_height = section.settings.mobile_image.width | divided_by: section.settings.mobile_image.aspect_ratio
  elsif section.settings.image != blank
    assign mobile_image_height = desktop_image_height
  endif
  assign image_height = desktop_image_height | default: mobile_image_height
%}

{%- style -%}
  #shopify-section-{{ section.id }} {
  	--image-height-mobile: {{ mobile_section_size }};
  	--image-height-desktop: {{ desktop_section_size }};
  }
{%- endstyle -%}

<div
  class="color-inverse image-banner section-{{ section.id }}-padding {% if section.settings.overlay_enable %}have-overlay{% endif %}"
  {% if has_overlay %}
    data-header-overlay="true"
  {% endif %}
>
  <div class="image-banner__img dynamic-image">
    {%- if image and image != 1 -%}
      {{
        image
        | image_url: width: 3840
        | image_tag:
          loading: 'lazy',
          width: image.width,
          height: image_height,
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          class: 'only_desktop_image'
      }}
    {% elsif image == 1 %}
      {{
        section.settings.image
        | image_url: width: 3840
        | image_tag:
          loading: 'lazy',
          width: section.settings.image.width,
          height: desktop_image_height,
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          class: 'desktop_image'
      }}
      {{
        section.settings.mobile_image
        | image_url: width: section.settings.mobile_image.width
        | image_tag:
          loading: 'lazy',
          width: section.settings.mobile_image.width,
          height: mobile_image_height,
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          class: 'mobile_image'
      }}
    {%- endif -%}
  </div>
  <div class="container image-banner__wrapper">
    <div class="image-banner__block">
      {%- if section.settings.subheading != blank or section.settings.heading != blank -%}
        <div class="image-banner__block-header">
          {%- if section.settings.subheading != blank -%}
            <div class="image-banner__block-header-subheading subtitle">
              {{ section.settings.subheading }}
            </div>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <{{ section.settings.heading_tag }} class="image-with-description__block-heading h2">
              {{ section.settings.heading }}
            </{{ section.settings.heading_tag }}>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="image-banner__block-info">
        {%- if section.settings.text != blank -%}
          <div class="image-banner__block-info__text">
            {{ section.settings.text }}
          </div>
        {%- endif -%}
        <div class="image-banner-author__block">
          {%- if section.settings.author_position != blank -%}
            <div class="image-banner-author__position subtitle">
              {{ section.settings.author_position }}
            </div>
          {%- endif -%}
          {%- if section.settings.author_name != blank -%}
            <div class="image-banner-author__name">
              {{ section.settings.author_name }}
            </div>
          {%- endif -%}
        </div>
      </div>

      {% if section.settings.button_label != blank %}
        <div class="image-banner__button-wrapper">
          {% render 'button', layout: section, icon: true %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.image-banner.name",
  "class": "image-banner-section spaced-section",
  "tag": "section",
  "enabled_on": {
    "templates": ["*"],
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.image.header.content"
    },
    {
      "type": "checkbox",
      "id": "header_overlay",
      "label": "t:sections.all.header_overlay.label",
      "info": "t:sections.all.header_overlay.info",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.all.image.label"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "t:sections.all.mobile_image.label"
    },
    {
      "type": "select",
      "id": "image_size",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.all.image.size.options__1.label"
        },
        {
          "value": "small",
          "label": "t:sections.all.image.size.options__2.label"
        },
        {
          "value": "medium",
          "label": "t:sections.all.image.size.options__3.label"
        },
        {
          "value": "large",
          "label": "t:sections.all.image.size.options__4.label"
        }
      ],
      "default": "medium",
      "label": "t:sections.image-banner.settings.image_size.label"
    },
    {
      "type": "select",
      "id": "mobile_image_size",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.all.image.size.options__1.label"
        },
        {
          "value": "small",
          "label": "t:sections.all.image.size.options__2.label"
        },
        {
          "value": "medium",
          "label": "t:sections.all.image.size.options__3.label"
        },
        {
          "value": "large",
          "label": "t:sections.all.image.size.options__4.label"
        }
      ],
      "default": "medium",
      "label": "t:sections.image-banner.settings.mobile_image_size.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.overlay.header.content"
    },
    {
      "type": "checkbox",
      "id": "overlay_enable",
      "default": true,
      "label": "t:sections.all.overlay.overlay_enable.label"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 10,
      "max": 90,
      "default": 20,
      "unit": "%",
      "label": "t:sections.all.overlay.overlay_opacity.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.heading.header.content"
    },
    {
      "type": "text",
      "id": "subheading",
      "default": "t:sections.image-banner.settings.subheading.default",
      "label": "t:sections.all.subheading.label"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.image-banner.settings.heading.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        },
        {
          "value": "p",
          "label": "t:sections.all.heading_tag.options__8.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_tag.label",
      "info": "t:sections.all.heading_tag.info"
    },
    {
      "type": "textarea",
      "id": "text",
      "default": "t:sections.image-banner.settings.text.default",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.author.header.content"
    },
    {
      "type": "text",
      "id": "author_position",
      "default": "t:sections.all.author.author_position.default",
      "label": "t:sections.all.author.author_position.label"
    },
    {
      "type": "text",
      "id": "author_name",
      "default": "t:sections.all.author.author_name.default",
      "label": "t:sections.all.author.author_name.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.button.header.content"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "t:sections.image-banner.settings.button.default",
      "label": "t:sections.all.button.label.label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.all.button.link.label"
    },
    {
      "type": "select",
      "id": "button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.style.options__2.label"
        }
      ],
      "default": "primary",
      "label": "t:sections.all.button.style.label"
    },
    {
      "type": "checkbox",
      "id": "button_arrow",
      "default": true,
      "label": "t:sections.all.button.arrow.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section_padding.header.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 0,
      "unit": "px",
      "label": "t:sections.all.section_padding.padding_top.label"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 0,
      "unit": "px",
      "label": "t:sections.all.section_padding.padding_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section_margin.header.content"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 20,
      "unit": "px",
      "label": "t:sections.all.section_margin.margin_top.label"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 20,
      "unit": "px",
      "label": "t:sections.all.section_margin.margin_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.image-banner.name"
    }
  ]
}
{% endschema %}
