{{ 'section-faq.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% render 'spaced-section' %}
  {% render 'spaced-section-inner' %}
{%- endstyle -%}

<link
  rel="stylesheet"
  href="{{ 'component-accordion.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

<link
  rel="stylesheet"
  href="{{ 'component-list-menu.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

<div class="faq color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="faq-header center">
    <div class="container">
      {%- if section.settings.subheading != blank -%}
        <div class="faq__subtitle subtitle">{{ section.settings.subheading }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }} class="faq__title h2">
          {{ section.settings.heading | escape }}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}
    </div>
    {% if section.settings.enable_inner_border %}<div class="section_inner_border"></div>{% endif %}
  </div>
  <div class="container">
    <div class="faq-box">
      {% for block in section.blocks %}
        {% if block.settings.block_heading != blank and block.settings.text != blank %}
          <div class="faq-block">
            <div class="accordion faq-item">
              <details
                {% if block.settings.default_open %}
                  open
                {% endif %}
              >
                <summary>
                  <{{ block.settings.heading_tag }} class="faq-block__heading h2">
                    {{ block.settings.block_heading | escape }}
                  </{{ block.settings.heading_tag }}>
                  {% render 'icon-filter-two' %}
                </summary>
                <div class="faq-block__description">
                  {{ block.settings.text }}
                </div>
              </details>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.faq.name",
  "class": "spaced-section blockqoute-section",
  "tag": "section",
  "enabled_on": {
    "templates": ["*"],
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "background-1",
          "label": "t:sections.all.color_scheme.options__1.label"
        },
        {
          "value": "background-2",
          "label": "t:sections.all.color_scheme.options__2.label"
        },
        {
          "value": "background-3",
          "label": "t:sections.all.color_scheme.options__3.label"
        },
        {
          "value": "background-4",
          "label": "t:sections.all.color_scheme.options__4.label"
        },
        {
          "value": "background-5",
          "label": "t:sections.all.color_scheme.options__5.label"
        },
        {
          "value": "inverse",
          "label": "t:sections.all.color_scheme.options__6.label"
        }
      ],
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "text",
      "id": "subheading",
      "default": "t:sections.faq.settings.subheading.default",
      "label": "t:sections.all.subheading.label"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.faq.settings.heading.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        },
        {
          "value": "p",
          "label": "t:sections.all.heading_tag.options__8.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_tag.label",
      "info": "t:sections.all.heading_tag.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.section_padding.header.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 20,
      "unit": "px",
      "label": "t:sections.all.section_padding.padding_top.label"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 20,
      "unit": "px",
      "label": "t:sections.all.section_padding.padding_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section_margin.header.content"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 0,
      "unit": "px",
      "label": "t:sections.all.section_margin.margin_top.label"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 0,
      "unit": "px",
      "label": "t:sections.all.section_margin.margin_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.border.header.content"
    },
    {
      "type": "checkbox",
      "id": "enable_inner_border",
      "default": false,
      "label": "t:sections.all.border.border_enable_inner.label"
    }
  ],
  "blocks": [
    {
      "type": "text-block",
      "name": "t:sections.faq.blocks.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "block_heading",
          "default": "t:sections.faq.blocks.settings.heading.default",
          "label": "t:sections.all.heading.label"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "options": [
            {
              "value": "h1",
              "label": "t:sections.all.heading_tag.options__1.label"
            },
            {
              "value": "h2",
              "label": "t:sections.all.heading_tag.options__2.label"
            },
            {
              "value": "h3",
              "label": "t:sections.all.heading_tag.options__3.label"
            },
            {
              "value": "h4",
              "label": "t:sections.all.heading_tag.options__4.label"
            },
            {
              "value": "h5",
              "label": "t:sections.all.heading_tag.options__5.label"
            },
            {
              "value": "h6",
              "label": "t:sections.all.heading_tag.options__6.label"
            },
            {
              "value": "div",
              "label": "t:sections.all.heading_tag.options__7.label"
            },
            {
              "value": "p",
              "label": "t:sections.all.heading_tag.options__8.label"
            }
          ],
          "default": "h2",
          "label": "t:sections.all.heading_tag.label",
          "info": "t:sections.all.heading_tag.info"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "t:sections.faq.blocks.settings.description.default",
          "label": "t:sections.all.text.label"
        },
        {
          "type": "checkbox",
          "id": "default_open",
          "default": false,
          "label": "t:sections.faq.blocks.settings.default_open.label",
          "info": "t:sections.faq.blocks.settings.default_open.info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.faq.name",
      "blocks": [
        {
          "type": "text-block"
        },
        {
          "type": "text-block"
        },
        {
          "type": "text-block"
        }
      ]
    }
  ]
}
{% endschema %}
